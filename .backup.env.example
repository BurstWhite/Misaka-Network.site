# rclone remote name configured by `rclone config`.
RCLONE_REMOTE=r2

# Use a concrete bucket path. Do not point this at the remote root.
RCLONE_DEST=your-bucket/backups/Misaka-Network.site

# Backup retention for both local archives and remote R2 objects.
BACKUP_RETENTION_DAYS=30

# Local staging directory. Contents are ignored by storage/backup/.gitignore.
BACKUP_LOCAL_DIR=storage/backup/r2

# Logs can grow quickly. Keep them out unless you explicitly need them.
BACKUP_INCLUDE_LOGS=false

# Useful for Cloudflare R2 bucket-scoped tokens.
BACKUP_RCLONE_EXTRA_ARGS=--s3-no-check-bucket
