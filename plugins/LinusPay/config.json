        "merchant_private_key": {
            "type": "text",
            "label": "商户私钥",
            "default": ""
        },
        "platform_public_key": {
            "type": "text",
            "label": "平台公钥",
            "default": ""
        },
        "type": {
            "type": "string",
            "label": "支付方式",
            "default": ""
        }
    }
}
